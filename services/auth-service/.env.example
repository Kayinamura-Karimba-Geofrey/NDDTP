# Application
NODE_ENV=development
APP_NAME=nddtp-auth-service
APP_PORT=3001
APP_HOST=0.0.0.0
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:4200

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=nddtp_auth
DB_PASSWORD=change_me_secure_password
DB_NAME=nddtp_auth
DB_SSL=false
DB_LOGGING=false
DB_POOL_SIZE=10

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL_DEFAULT=300
REDIS_TTL_SESSION=3600
REDIS_TTL_REFRESH_TOKEN=604800

# RabbitMQ
RABBITMQ_URL=amqp://nddtp:change_me@localhost:5672
RABBITMQ_EXCHANGE=nddtp.events
RABBITMQ_DLX_EXCHANGE=nddtp.events.dlx
RABBITMQ_QUEUE_PREFIX=auth-service

# JWT
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars_long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars_long
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=nddtp-auth-service
JWT_AUDIENCE=nddtp-platform

# Security
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30
PASSWORD_RESET_TOKEN_EXPIRES_HOURS=1
MFA_ISSUER=NDDTP
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
