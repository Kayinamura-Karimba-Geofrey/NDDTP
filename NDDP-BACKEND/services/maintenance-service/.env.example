NODE_ENV=development
APP_NAME=nddtp-maintenance-service
APP_PORT=3018
APP_HOST=0.0.0.0
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3000

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=nddtp_maintenance
DB_PASSWORD=change_me_secure_password
DB_NAME=nddtp_maintenance
DB_SSL=false
DB_LOGGING=false
DB_POOL_SIZE=10

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=17

RABBITMQ_URL=amqp://nddtp:change_me@localhost:5672
RABBITMQ_EXCHANGE=nddtp.events
RABBITMQ_DLX_EXCHANGE=nddtp.events.dlx
RABBITMQ_QUEUE_PREFIX=maintenance-service

JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars_long
JWT_ISSUER=nddtp-auth-service
JWT_AUDIENCE=nddtp-platform

RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=200
